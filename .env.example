# Copy this file to .env and fill in the values before running the app.
# Never commit .env to version control.

# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional: email address used to send confirmations and password reset links.
# If left empty the app still works — emails are just skipped.
EMAIL_SENDER=youraddress@gmail.com

# Gmail app password (not your regular password).
# Create one at https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=your-app-password-here
